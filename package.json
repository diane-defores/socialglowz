{
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.92",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@vueuse/core": "^12.8.2",
    "convex": "^1.39.1",
    "marked": "^15.0.12",
    "notivue": "^2.4.5",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "4.2.0",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primevue": "^3.53.1",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.4",
    "vue-router": "^4.6.4",
    "webextension-polyfill": "^0.12.0"
  },
  "description": "Un projet Vue 3 + Vite pour la construction d'extensions Chrome",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@iconify-json/ph": "^1.2.2",
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2.11.2",
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.19.41",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/compiler-sfc": "^3.5.35",
    "autoprefixer": "^10.5.0",
    "chalk": "^5.6.2",
    "chrome-types": "^0.1.429",
    "commander": "^13.1.0",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.53",
    "cross-env": "^7.0.3",
    "daisyui": "^4.12.24",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "tailwindcss": "^3.4.19",
    "terser": "^5.48.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-icons": "^22.5.0",
    "unplugin-turbo-console": "^1.11.3",
    "unplugin-vue-components": "^28.8.0",
    "unplugin-vue-router": "^0.10.9",
    "vite": "^6.4.2",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vite-plugin-zip-pack": "^1.2.4",
    "vitest": "^4.1.7",
    "vue-tsc": "^2.2.12",
    "web-ext": "^10.3.0"
  },
  "displayName": "Vite Vue 3 Chrome Extension",
  "engines": {
    "node": ">=20 <23"
  },
  "license": "UNLICENSED",
  "name": "vite-vue3-browser-extension-v3",
  "overrides": {
    "@crxjs/vite-plugin": "$@crxjs/vite-plugin"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "@babel/helpers": "^7.29.2",
      "@babel/runtime": "^7.29.2",
      "@eslint/plugin-kit": "^0.3.4",
      "@nuxt/kit": "^3.21.2",
      "ajv@6": "6.15.0",
      "ajv@8": "8.20.0",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "defu": "^6.1.7",
      "flatted": "^3.4.2",
      "glob@10": "^10.5.0",
      "h3": "^1.15.9",
      "image-size": "^1.2.1",
      "immutable": "^5.1.5",
      "js-yaml": "^4.1.1",
      "lodash": "^4.18.0",
      "minimatch@3": "3.1.4",
      "minimatch@5": "5.1.8",
      "minimatch@9": "9.0.9",
      "node-forge": "^1.4.0",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "postcss": "^8.5.12",
      "rollup@2": "2.80.0",
      "rollup@4": "^4.60.2",
      "serialize-javascript": "^7.0.5",
      "svgo": "^3.3.3",
      "tmp": "^0.2.6",
      "undici": "^6.25.0",
      "yaml": "^2.8.3",
      "ws": "8.20.1"
    },
    "peerDependencyRules": {
      "allowAny": [],
      "allowedDeprecatedVersions": {
        "sourcemap-codec": "1.4.8"
      },
      "allowedVersions": {
        "node-fetch": "*"
      },
      "ignoreMissing": []
    }
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/mubaidr/vite-vue3-browser-extension-v3"
  },
  "scripts": {
    "tauri:info": "pnpm exec tauri info",
    "tauri:dev": "vite -c vite.tauri.config.ts",
    "tauri:build": "vite build -c vite.tauri.config.ts",
    "tauri:bundle": "pnpm tauri:build && pnpm exec tauri build --no-bundle",
    "tauri:android:init": "pnpm exec tauri android init",
    "tauri:android:dev": "pnpm exec tauri android dev",
    "tauri:android:build": "pnpm exec tauri android build",
    "tauri:ios:init": "pnpm exec tauri ios init",
    "tauri:ios:dev": "pnpm exec tauri ios dev",
    "tauri:ios:build": "pnpm exec tauri ios build",
    "tauri": "pnpm exec tauri",
    "build": "corepack pnpm run build:chrome && corepack pnpm run build:firefox",
    "build:chrome": "cross-env NODE_ENV=production vite build -c vite.chrome.config.ts",
    "build:firefox": "cross-env NODE_ENV=production vite build -c vite.firefox.config.ts",
    "dev": "concurrently \"pnpm run dev:chrome\" \"pnpm run dev:firefox\"",
    "dev:chrome": "cross-env NODE_ENV=development vite -c vite.chrome.config.ts",
    "dev:firefox": "cross-env NODE_ENV=development vite build --mode development --watch -c vite.firefox.config.ts",
    "format": "prettier --write .",
    "launch": "tsx scripts/launch.ts",
    "launch:all": "tsx scripts/launch.ts --all",
    "lint": "eslint . --fix --cache",
    "lint:check": "eslint . --cache",
    "lint:manifest": "web-ext lint --source-dir dist/firefox --pretty",
    "test": "vitest",
    "test:once": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.core.json",
    "typecheck:core": "tsc --noEmit -p tsconfig.typecheck.core.json",
    "typecheck:full": "vue-tsc --noEmit -p tsconfig.json",
    "preview": "vite preview"
  },
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@8.11.0"
}
