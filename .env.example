# metadata_schema_version: "1.0"
# project: socialflow
# updated: "2026-04-26"
# title: SocialFlow environment variables
#
# Convex — required for auth and data persistence
# Get your URL from `npx convex dev` or the Convex dashboard
VITE_CONVEX_URL=

# Convex site domain used by Convex Auth (optional for local/dev configs)
CONVEX_SITE_URL=

# Billing / product access bridge
# Server/operator only. Never expose these in browser or mobile builds.
SOCIALGLOWZ_BILLING_ADMIN_SECRET=
SOCIALGLOWZ_SUITE_BRIDGE_URL=
SOCIALGLOWZ_SUITE_BRIDGE_SECRET=

# Gmail API — optional, only needed for Gmail integration
VITE_GMAIL_CLIENT_ID=
VITE_GMAIL_API_KEY=

# Optional runtime env (uncomment if your deploy pipeline uses these)
# CONVEX_DEPLOYMENT=
